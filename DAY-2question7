#include <stdio.h>
#include <stdlib.h>

int main()
{
    int num, temp, remainder, product = 1;
    printf("Enter an integer: ");
    scanf("%d", &num);
    temp = num;
    num = abs(num);
    if (num == 0)
{
        product = 0;
}
    while (num > 0) {
        remainder = num % 10;     
        product = product * remainder; 
        num = num / 10;          
    }
    printf("The product of the digits of %d is %d\n", temp, product);
    return 0;
}

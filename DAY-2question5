#include <stdio.h>
#include <stdlib.h>
int main()
{
    int num, temp, remainder, sum = 0;
    printf("Enter an integer: ");
    scanf("%d", &num);
    temp = num;
    num = abs(num);
    while (num > 0) 
{
        remainder = num % 10; 
        sum = sum + remainder; 
        num = num / 10;       
    }
    printf("The sum of the digits of %d is %d\n", temp, sum);
   return 0;
}

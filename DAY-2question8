#include <stdio.h>
#include <stdlib.h>

int main()
{
    int num, temp, remainder, reversed = 0;
    printf("Enter an integer: ");
    scanf("%d", &num);
    temp = num;
    num = abs(num);
    while (num > 0)
   {
        remainder = num % 10;
        reversed = (reversed * 10) + remainder;
        num = num / 10;
    }
    if (abs(temp) == reversed) ]
   {
        printf("%d is a palindrome number.\n", temp);
    }
else
     {
        printf("%d is not a palindrome number.\n", temp);
    }
   return 0;
}

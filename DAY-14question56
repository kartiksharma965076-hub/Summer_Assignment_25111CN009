#include <stdio.h>

int main() {
    int n, i, j;
    int duplicate_found = 0;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    int arr[n];
    int visited[n];

    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &arr[i]);
        visited[i] = 0; 
    }

    printf("\nDuplicate elements in the array: ");
    for (i = 0; i < n; i++) {
        if (visited[i] == 1) {
            continue;
        }

        int count = 1;
        for (j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                visited[j] = 1; 
            }
        }

        if (count > 1) {
            printf("%d ", arr[i]);
            duplicate_found = 1;
        }
    }

    if (duplicate_found == 0) {
        printf("None");
    }
    printf("\n");

    return 0;
}

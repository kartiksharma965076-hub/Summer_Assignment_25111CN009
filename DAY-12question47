#include <stdio.h>

void print_fibonacci(int n) {
    int t1 = 0, t2 = 1, next_term;

    for (int i = 1; i <= n; i++) {
        printf("%d ", t1);
        next_term = t1 + t2;
        t1 = t2;
        t2 = next_term;
    }
    printf("\n");
}

int main() {
    int terms;

    printf("Enter number of terms: ");
    if (scanf("%d", &terms) != 1 || terms <= 0) {
        printf("Invalid input.\n");
        return 1;
    }

    printf("Fibonacci Series: ");
    print_fibonacci(terms);

    return 0;
}

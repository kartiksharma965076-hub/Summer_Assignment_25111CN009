#include <stdio.h>
#include <math.h>
int main() 
{
    int num, temp, rem, digits = 0;
    long long sum = 0;
    printf("Enter an integer: ");
    scanf("%d", &num);
    temp = num;
    while (temp != 0) 
{
        digits++;
        temp = temp / 10;
    }
   temp = num;
    while (temp != 0)
{
        rem = temp % 10
        sum = sum + round(pow(rem, digits)); 
        temp = temp / 10;
    }
    if (sum == num) 
{
        printf("%d is an Armstrong number.\n", num);
    }
else
{
        printf("%d is not an Armstrong number.\n", num);
    }
  return 0;
}

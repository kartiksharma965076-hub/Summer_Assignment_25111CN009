#include <stdio.h>
int main() 
{
    int num, i;
    int sum = 0;
    printf("Enter any positive integer: ");
    scanf("%d", &num);
    if (num <= 0)
{
        printf("%d is NOT a perfect number.\n", num);
        return 0;
    }
    for (i = 1; i <= num / 2; i++) {
        if (num % i == 0) {
            sum += i; 
        }
    }
    if (sum == num)
{
        printf("%d is a PERFECT NUMBER.\n", num);
    } 
else 
{
        printf("%d is NOT a perfect number.\n", num);
    }
    return 0;
}

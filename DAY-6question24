#include <stdio.h>
int main() 
{
    int x, n;
    long long result = 1;
    printf("Enter base (x) and exponent (n): ");
    if (scanf("%d %d", &x, &n) != 2 || n < 0) 
{
        printf("Invalid input.\n");
        return 1;
    }
  for (int i = 0; i < n; i++) 
{
        result = result * x;
    }
 printf("%d raised to the power of %d is: %lld\n", x, n, result);
return 0;
}

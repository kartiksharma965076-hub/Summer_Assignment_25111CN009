#include <stdio.h>
int main() 
{
    int binary, decimal = 0, weight = 1, rem;
    printf("Enter a binary number: ");
    if (scanf("%d", &binary) != 1) 
    {
        printf("Invalid input.\n");
        return 1;
    }
   while (binary > 0)
   {
        rem = binary % 10;
        decimal = decimal + (rem * weight);
        binary = binary / 10;
        weight = weight * 2;
    }
  printf("Decimal equivalent: %d\n", decimal);
  return 0;
}

#include <stdio.h>
int main() 
{
    int num, count = 0;
    printf("Enter a number: ");
    if (scanf("%d", &num) != 1)
{
        printf("Invalid input.\n");
        return 1;
    }
    while (num > 0)
{
        if (num & 1)
{
            count++;
        }
        num = num >> 1;
    }

    printf("Total set bits: %d\n", count);

    return 0;
}

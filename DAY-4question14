#include <stdio.h>
int main() 
{
    int n;
    printf("Enter the position (n): ");
    scanf("%d", &n);
    long long first = 0;
    long long second = 1;
    long long next_val = 0;
    if (n == 0)
{
        printf("The result is: 0\n");
        return 0;
    }
    if (n == 1)
{
        printf("The result is: 1\n");
        return 0;
    }
    for (int i = 2; i <= n; i++)
{
        next_val = first + second;
        first = second;
        second = next_val;
    }
   printf("The %dth Fibonacci term is: %lld\n", n, second);
   return 0;
}

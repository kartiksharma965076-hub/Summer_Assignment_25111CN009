#include <stdio.h>

int find_sum(int a, int b) {
    return a + b;
}

int main() {
    int num1, num2, result;

    printf("Enter two numbers: ");
    if (scanf("%d %d", &num1, &num2) != 2) {
        printf("Invalid input.\n");
        return 1;
    }

    result = find_sum(num1, num2);

    printf("Sum: %d\n", result);

    return 0;
}
